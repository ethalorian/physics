## Lesson Navigation

### Unit-Based Lesson List
```typescript
interface LessonListProps {
  unitId: string
  lessons: Lesson[]
  currentLessonId?: string
  onSelectLesson: (lesson: Lesson) => void
}

export function LessonList({
  unitId,
  lessons,
  currentLessonId,
  onSelectLesson
}: LessonListProps) {
  const unitLessons = lessons
    .filter(l => l.unit_id === unitId && l.published)
    .sort((a, b) => a.slug.localeCompare(b.slug))
  
  return (
    <div className="space-y-2">
      {unitLessons.map((lesson, index) => (
        <button
          key={lesson.id}
          onClick={() => onSelectLesson(lesson)}
          className={cn(
            "w-full text-left p-4 rounded-lg border transition-colors",
            "hover:bg-accent hover:text-accent-foreground",
            currentLessonId === lesson.id && "bg-primary text-primary-foreground"
          )}
        >
          <div className="flex items-center justify-between">
            <div>
              <p className="font-medium">{index + 1}. {lesson.title}</p>
              <p className="text-sm opacity-80">{lesson.estimated_time} min</p>
            </div>
            <Badge variant={lesson.difficulty === 'hard' ? 'destructive' : 'secondary'}>
              {lesson.difficulty}
            </Badge>
          </div>
        </button>
      ))}
    </div>
  )
}
```

## Progress Tracking

### Lesson Progress Management
```typescript
interface LessonProgress {
  lessonId: string
  userId: string
  status: 'not_started' | 'in_progress' | 'completed'
  progress_percentage: number
  time_spent: number // seconds
  last_accessed: string
  completed_at?: string
  quiz_score?: number
}

const updateLessonProgress = async (
  lessonId: string,
  userId: string,
  updates: Partial<LessonProgress>
) => {
  const { data, error } = await supabase
    .from('lesson_progress')
    .upsert({
      lesson_id: lessonId,
      user_id: userId,
      ...updates,
      last_accessed: new Date().toISOString()
    }, {
      onConflict: 'lesson_id,user_id'
    })
  
  if (error) throw error
  return data
}

// Track reading progress
const useReadingProgress = (lessonId: string, userId: string) => {
  const [scrollProgress, setScrollProgress] = useState(0)
  const saveProgressRef = useRef<NodeJS.Timeout>()
  
  useEffect(() => {
    const handleScroll = () => {
      const scrollHeight = document.documentElement.scrollHeight - window.innerHeight
      const scrolled = window.scrollY
      const progress = Math.round((scrolled / scrollHeight) * 100)
      
      setScrollProgress(progress)
      
      // Debounced save
      if (saveProgressRef.current) {
        clearTimeout(saveProgressRef.current)
      }
      
      saveProgressRef.current = setTimeout(() => {
        updateLessonProgress(lessonId, userId, {
          progress_percentage: progress,
          status: progress >= 90 ? 'completed' : 'in_progress'
        })
      }, 2000)
    }
    
    window.addEventListener('scroll', handleScroll)
    return () => window.removeEventListener('scroll', handleScroll)
  }, [lessonId, userId])
  
  return scrollProgress
}
```

