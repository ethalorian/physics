# Enhanced Lesson Management System

## Lesson Data Structure

### Core Lesson Interface
```typescript
interface Lesson {
  id: string
  slug: string
  unit_id: string
  title: string
  description: string
  content: string // Markdown with KaTeX math
  objectives: string[]
  prerequisites: string[]
  difficulty: 'easy' | 'medium' | 'hard'
  estimated_time: number // minutes
  published: boolean
  video_id?: string
  simulation_ids?: string[]
  vocabulary_terms?: string[]
  practice_questions?: string[]
  created_at: string
  updated_at: string
}
```

## Lesson Editor Component

### Rich Content Editor
```typescript
'use client'

import { useState, useCallback } from 'react'
import { Button } from '@/components/ui/button'
import { Input } from '@/components/ui/input'
import { Textarea } from '@/components/ui/textarea'
import { Label } from '@/components/ui/label'
import MathMarkdown from '@/components/MathMarkdown'
import { Tabs, TabsContent, TabsList, TabsTrigger } from '@/components/ui/tabs'

interface LessonEditorProps {
  lesson?: Lesson
  onSave: (lesson: Partial<Lesson>) => Promise<void>
  onCancel: () => void
}

export function LessonEditor({ lesson, onSave, onCancel }: LessonEditorProps) {
  const [formData, setFormData] = useState<Partial<Lesson>>(
    lesson || {
      title: '',
      description: '',
      content: '',
      objectives: [''],
      prerequisites: [],
      difficulty: 'medium',
      estimated_time: 30,
      published: false
    }
  )
  
  const [activeTab, setActiveTab] = useState<'edit' | 'preview'>('edit')
  const [saving, setSaving] = useState(false)
  
  const updateField = (field: keyof Lesson, value: any) => {
    setFormData(prev => ({ ...prev, [field]: value }))
  }
  
  const addObjective = () => {
    setFormData(prev => ({
      ...prev,
      objectives: [...(prev.objectives || []), '']
    }))
  }
  
  const updateObjective = (index: number, value: string) => {
    setFormData(prev => ({
      ...prev,
      objectives: prev.objectives?.map((obj, i) => i === index ? value : obj)
    }))
  }
  
  const removeObjective = (index: number) => {
    setFormData(prev => ({
      ...prev,
      objectives: prev.objectives?.filter((_, i) => i !== index)
    }))
  }
  
  const handleSave = async () => {
    setSaving(true)
    try {
      await onSave(formData)
    } finally {
      setSaving(false)
    }
  }
  
  return (
    <div className="max-w-4xl mx-auto space-y-6">
      {/* Basic Info */}
      <div className="space-y-4">
        <div className="space-y-2">
          <Label htmlFor="title">Lesson Title *</Label>
          <Input
            id="title"
            value={formData.title}
            onChange={(e) => updateField('title', e.target.value)}
            placeholder="e.g., Newton&apos;s First Law of Motion"
          />
        </div>
        
        <div className="space-y-2">
          <Label htmlFor="description">Description</Label>
          <Textarea
            id="description"
            value={formData.description}
            onChange={(e) => updateField('description', e.target.value)}
            placeholder="Brief description of the lesson"
            rows={3}
          />
        </div>
        
        <div className="grid grid-cols-2 gap-4">
          <div className="space-y-2">
            <Label htmlFor="difficulty">Difficulty</Label>
            <Select
              value={formData.difficulty}
              onValueChange={(value) => updateField('difficulty', value)}
            >
              <SelectTrigger>
                <SelectValue />
              </SelectTrigger>
              <SelectContent>
                <SelectItem value="easy">Easy</SelectItem>
                <SelectItem value="medium">Medium</SelectItem>
                <SelectItem value="hard">Hard</SelectItem>
              </SelectContent>
            </Select>
          </div>
          
          <div className="space-y-2">
            <Label htmlFor="time">Estimated Time (minutes)</Label>
            <Input
              id="time"
              type="number"
              value={formData.estimated_time}
              onChange={(e) => updateField('estimated_time', parseInt(e.target.value))}
            />
          </div>
        </div>
      </div>
      
      {/* Learning Objectives */}
      <div className="space-y-2">
        <div className="flex justify-between items-center">
          <Label>Learning Objectives</Label>
          <Button variant="outline" size="sm" onClick={addObjective}>
            Add Objective
          </Button>
        </div>
        {formData.objectives?.map((objective, index) => (
          <div key={index} className="flex space-x-2">
            <Input
              value={objective}
              onChange={(e) => updateObjective(index, e.target.value)}
              placeholder={`Objective ${index + 1}`}
            />
            <Button
              variant="ghost"
              size="icon"
              onClick={() => removeObjective(index)}
            >
              <X className="h-4 w-4" />
            </Button>
          </div>
        ))}
      </div>
      
      {/* Content Editor with Preview */}
      <div className="space-y-2">
        <Label>Lesson Content</Label>
        <Tabs value={activeTab} onValueChange={(v) => setActiveTab(v as any)}>
          <TabsList>
            <TabsTrigger value="edit">Edit</TabsTrigger>
            <TabsTrigger value="preview">Preview</TabsTrigger>
          </TabsList>
          
          <TabsContent value="edit" className="mt-4">
            <Textarea
              value={formData.content}
              onChange={(e) => updateField('content', e.target.value)}
              placeholder="Write lesson content with markdown. Use \\( ... \\) for inline math and \\[ ... \\] for display math."
              rows={20}
              className="font-mono text-sm"
            />
            <p className="text-sm text-muted-foreground mt-2">
              Supports Markdown and KaTeX math notation
            </p>
          </TabsContent>
          
          <TabsContent value="preview" className="mt-4">
            <div className="border rounded-lg p-6 min-h-[400px] bg-background">
              <MathMarkdown content={formData.content || '*No content yet*'} />
            </div>
          </TabsContent>
        </Tabs>
      </div>
      
      {/* Media Integration */}
      <div className="space-y-4 border-t pt-4">
        <h3 className="text-lg font-medium">Media Integration</h3>
        
        <div className="space-y-2">
          <Label htmlFor="video">YouTube Video ID</Label>
          <Input
            id="video"
            value={formData.video_id || ''}
            onChange={(e) => updateField('video_id', e.target.value)}
            placeholder="e.g., dQw4w9WgXcQ"
          />
        </div>
      </div>
      
      {/* Actions */}
      <div className="flex justify-between items-center border-t pt-4">
        <div className="flex items-center space-x-2">
          <input
            type="checkbox"
            id="published"
            checked={formData.published}
            onChange={(e) => updateField('published', e.target.checked)}
          />
          <Label htmlFor="published">Publish lesson</Label>
        </div>
        
        <div className="flex space-x-2">
          <Button variant="outline" onClick={onCancel}>
            Cancel
          </Button>
          <Button onClick={handleSave} disabled={saving}>
            {saving ? 'Saving...' : lesson ? 'Update Lesson' : 'Create Lesson'}
          </Button>
        </div>
      </div>
    </div>
  )
}
```

