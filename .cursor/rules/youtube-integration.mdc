# YouTube Player API Integration

## Player Initialization

### Loading the IFrame API
```typescript
'use client'

import { useEffect, useRef, useState } from 'react'

// Extend Window interface for YouTube API
declare global {
  interface Window {
    YT: typeof YT
    onYouTubeIframeAPIReady: () => void
  }
}

function useYouTubePlayer(videoId: string) {
  const playerRef = useRef<YT.Player | null>(null)
  const [isReady, setIsReady] = useState(false)
  
  useEffect(() => {
    // Check if API already loaded
    if (window.YT) {
      initializePlayer()
      return
    }
    
    // Load YouTube IFrame API
    const tag = document.createElement('script')
    tag.src = 'https://www.youtube.com/iframe_api'
    const firstScriptTag = document.getElementsByTagName('script')[0]
    firstScriptTag.parentNode?.insertBefore(tag, firstScriptTag)
    
    // Set callback for when API is ready
    window.onYouTubeIframeAPIReady = () => {
      initializePlayer()
    }
    
    function initializePlayer() {
      playerRef.current = new window.YT.Player('youtube-player', {
        videoId: videoId,
        playerVars: {
          autoplay: 0,
          controls: 1,
          modestbranding: 1,
          rel: 0
        },
        events: {
          onReady: handleReady,
          onStateChange: handleStateChange,
          onError: handleError
        }
      })
    }
    
    return () => {
      playerRef.current?.destroy()
    }
  }, [videoId])
  
  return { player: playerRef.current, isReady }
}
```

## Player Control Methods

### Essential Controls
```typescript
interface YouTubePlayerControls {
  play: () => void
  pause: () => void
  stop: () => void
  seekTo: (seconds: number, allowSeekAhead: boolean) => void
  getCurrentTime: () => Promise<number>
  getDuration: () => Promise<number>
  getPlayerState: () => YT.PlayerState
  setVolume: (volume: number) => void
  mute: () => void
  unMute: () => void
}

function createPlayerControls(player: YT.Player): YouTubePlayerControls {
  return {
    play: () => player.playVideo(),
    pause: () => player.pauseVideo(),
    stop: () => player.stopVideo(),
    seekTo: (seconds, allowSeekAhead) => player.seekTo(seconds, allowSeekAhead),
    getCurrentTime: () => Promise.resolve(player.getCurrentTime()),
    getDuration: () => Promise.resolve(player.getDuration()),
    getPlayerState: () => player.getPlayerState(),
    setVolume: (volume) => player.setVolume(volume),
    mute: () => player.mute(),
    unMute: () => player.unMute()
  }
}
```

## Player States and Events

### State Management
```typescript
enum YouTubePlayerState {
  UNSTARTED = -1,
  ENDED = 0,
  PLAYING = 1,
  PAUSED = 2,
  BUFFERING = 3,
  CUED = 5
}

function usePlayerState(player: YT.Player | null) {
  const [playerState, setPlayerState] = useState<YouTubePlayerState>(
    YouTubePlayerState.UNSTARTED
  )
  const [isPlaying, setIsPlaying] = useState(false)
  
  useEffect(() => {
    if (!player) return
    
    const handleStateChange = (event: YT.OnStateChangeEvent) => {
      setPlayerState(event.data)
      setIsPlaying(event.data === YouTubePlayerState.PLAYING)
      
      // Custom event handling
      switch (event.data) {
        case YouTubePlayerState.ENDED:
          handleVideoEnded()
          break
        case YouTubePlayerState.PLAYING:
          handleVideoPlaying()
          break
        case YouTubePlayerState.PAUSED:
          handleVideoPaused()
          break
      }
    }
    
    // Note: Event binding happens in player initialization
  }, [player])
  
  return { playerState, isPlaying }
}
```

## Time Tracking and Progress

### Progress Monitoring
```typescript
function useVideoProgress(player: YT.Player | null, onProgress?: (progress: number) => void) {
  const [currentTime, setCurrentTime] = useState(0)
  const [duration, setDuration] = useState(0)
  const [progress, setProgress] = useState(0)
  
  useEffect(() => {
    if (!player) return
    
    const updateProgress = async () => {
      const time = await player.getCurrentTime()
      const dur = await player.getDuration()
      
      setCurrentTime(time)
      setDuration(dur)
      
      const prog = dur > 0 ? (time / dur) * 100 : 0
      setProgress(prog)
      
      onProgress?.(prog)
    }
    
    // Update every 100ms for smooth progress
    const interval = setInterval(updateProgress, 100)
    
    return () => clearInterval(interval)
  }, [player, onProgress])
  
  return { currentTime, duration, progress }
}
```

### Timestamp Utilities
```typescript
function formatTime(seconds: number): string {
  const minutes = Math.floor(seconds / 60)
  const secs = Math.floor(seconds % 60)
  return `${minutes}:${secs.toString().padStart(2, '0')}`
}

function parseTimestamp(timestamp: string): number {
  const parts = timestamp.split(':').map(Number)
  if (parts.length === 2) {
    return parts[0] * 60 + parts[1] // MM:SS
  } else if (parts.length === 3) {
    return parts[0] * 3600 + parts[1] * 60 + parts[2] // HH:MM:SS
  }
  return 0
}
```

## Custom Controls UI

### Progress Bar Component
```typescript
function VideoProgressBar({ 
  player, 
  currentTime, 
  duration,
  markers = [] 
}: VideoProgressBarProps) {
  const [isDragging, setIsDragging] = useState(false)
  const progressRef = useRef<HTMLDivElement>(null)
  
  const handleSeek = (e: React.MouseEvent<HTMLDivElement>) => {
    if (!player || !progressRef.current) return
    
    const rect = progressRef.current.getBoundingClientRect()
    const x = e.clientX - rect.left
    const percentage = x / rect.width
    const newTime = duration * percentage
    
    player.seekTo(newTime, true)
  }
  
  return (
    <div 
      ref={progressRef}
      className="relative h-2 bg-gray-700 rounded-full cursor-pointer group"
      onClick={handleSeek}
    >
      {/* Progress bar */}
      <div 
        className="absolute h-full bg-red-600 rounded-full transition-all"
        style={{ width: `${(currentTime / duration) * 100}%` }}
      />
      
      {/* Hover preview */}
      <div className="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity">
        {/* Could show thumbnail preview here */}
      </div>
      
      {/* Time markers (for questions, chapters, etc.) */}
      {markers.map((marker, i) => (
        <button
          key={i}
          className="absolute w-3 h-3 bg-yellow-500 rounded-full -top-0.5 transform -translate-x-1/2"
          style={{ left: `${(marker.time / duration) * 100}%` }}
          onClick={(e) => {
            e.stopPropagation()
            player.seekTo(marker.time, true)
          }}
          title={marker.label}
        />
      ))}
    </div>
  )
}
```

## Playlist Management

### Playlist Player
```typescript
interface PlaylistVideo {
  id: string
  videoId: string
  title: string
  description?: string
  duration: number
  order: number
}

function usePlaylist(videos: PlaylistVideo[]) {
  const [currentIndex, setCurrentIndex] = useState(0)
  const [currentVideo, setCurrentVideo] = useState(videos[0])
  
  const nextVideo = useCallback(() => {
    if (currentIndex < videos.length - 1) {
      const newIndex = currentIndex + 1
      setCurrentIndex(newIndex)
      setCurrentVideo(videos[newIndex])
    }
  }, [currentIndex, videos])
  
  const previousVideo = useCallback(() => {
    if (currentIndex > 0) {
      const newIndex = currentIndex - 1
      setCurrentIndex(newIndex)
      setCurrentVideo(videos[newIndex])
    }
  }, [currentIndex, videos])
  
  const selectVideo = useCallback((index: number) => {
    if (index >= 0 && index < videos.length) {
      setCurrentIndex(index)
      setCurrentVideo(videos[index])
    }
  }, [videos])
  
  return {
    currentVideo,
    currentIndex,
    nextVideo,
    previousVideo,
    selectVideo,
    hasNext: currentIndex < videos.length - 1,
    hasPrevious: currentIndex > 0
  }
}
```

## Error Handling

### Player Error Management
```typescript
enum YouTubeErrorCode {
  INVALID_PARAMETER = 2,
  HTML5_ERROR = 5,
  VIDEO_NOT_FOUND = 100,
  NOT_EMBEDDABLE = 101,
  NOT_EMBEDDABLE_DISGUISED = 150
}

function handlePlayerError(event: YT.OnErrorEvent) {
  const errorMessages = {
    [YouTubeErrorCode.INVALID_PARAMETER]: 'Invalid video parameter',
    [YouTubeErrorCode.HTML5_ERROR]: 'HTML5 player error',
    [YouTubeErrorCode.VIDEO_NOT_FOUND]: 'Video not found',
    [YouTubeErrorCode.NOT_EMBEDDABLE]: 'Video cannot be embedded',
    [YouTubeErrorCode.NOT_EMBEDDABLE_DISGUISED]: 'Video cannot be embedded (restricted)'
  }
  
  const message = errorMessages[event.data as YouTubeErrorCode] || 'Unknown error'
  console.error('YouTube Player Error:', message)
  
  // Show user-friendly error
  toast.error(`Video Error: ${message}`)
}
```

## Performance Optimization

### Lazy Loading Pattern
```typescript
function LazyYouTubePlayer({ videoId }: { videoId: string }) {
  const [shouldLoad, setShouldLoad] = useState(false)
  const thumbnailRef = useRef<HTMLDivElement>(null)
  
  useEffect(() => {
    const observer = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting) {
          setShouldLoad(true)
        }
      },
      { threshold: 0.25 }
    )
    
    if (thumbnailRef.current) {
      observer.observe(thumbnailRef.current)
    }
    
    return () => observer.disconnect()
  }, [])
  
  if (!shouldLoad) {
    return (
      <div 
        ref={thumbnailRef}
        className="relative cursor-pointer"
        onClick={() => setShouldLoad(true)}
      >
        <img 
          src={`https://img.youtube.com/vi/${videoId}/maxresdefault.jpg`}
          alt="Video thumbnail"
          className="w-full"
        />
        <div className="absolute inset-0 flex items-center justify-center">
          <div className="w-20 h-20 bg-red-600 rounded-full flex items-center justify-center">
            <Play className="w-10 h-10 text-white ml-1" />
          </div>
        </div>
      </div>
    )
  }
  
  return <YouTubePlayer videoId={videoId} />
}