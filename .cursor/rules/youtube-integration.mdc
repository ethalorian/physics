# YouTube Player API Integration

## Basic YouTube Player Setup

### Loading the API
```typescript
'use client'

import { useEffect, useRef, useState } from 'react'

// Extend Window interface for YouTube API
declare global {
  interface Window {
    YT: any
    onYouTubeIframeAPIReady: () => void
  }
}

const useYouTubeAPI = () => {
  const [apiReady, setApiReady] = useState(false)
  
  useEffect(() => {
    // Check if API already loaded
    if (window.YT && window.YT.Player) {
      setApiReady(true)
      return
    }
    
    // Load YouTube IFrame API script
    const tag = document.createElement('script')
    tag.src = 'https://www.youtube.com/iframe_api'
    tag.async = true
    
    const firstScriptTag = document.getElementsByTagName('script')[0]
    firstScriptTag.parentNode?.insertBefore(tag, firstScriptTag)
    
    // API ready callback
    window.onYouTubeIframeAPIReady = () => {
      setApiReady(true)
    }
    
    return () => {
      // Cleanup if component unmounts
      window.onYouTubeIframeAPIReady = () => {}
    }
  }, [])
  
  return apiReady
}
```

## Player Component

### Full-Featured YouTube Player
```typescript
interface YouTubePlayerProps {
  videoId: string
  onReady?: (player: any) => void
  onStateChange?: (state: number) => void
  onTimeUpdate?: (currentTime: number) => void
  autoplay?: boolean
  controls?: boolean
  startSeconds?: number
}

export function YouTubePlayer({
  videoId,
  onReady,
  onStateChange,
  onTimeUpdate,
  autoplay = false,
  controls = true,
  startSeconds = 0
}: YouTubePlayerProps) {
  const playerRef = useRef<any>(null)
  const containerRef = useRef<HTMLDivElement>(null)
  const timeUpdateIntervalRef = useRef<NodeJS.Timeout>()
  const apiReady = useYouTubeAPI()
  
  useEffect(() => {
    if (!apiReady || !containerRef.current) return
    
    // Initialize player
    playerRef.current = new window.YT.Player(containerRef.current, {
      videoId,
      playerVars: {
        autoplay: autoplay ? 1 : 0,
        controls: controls ? 1 : 0,
        start: startSeconds,
        modestbranding: 1,
        rel: 0,
        iv_load_policy: 3
      },
      events: {
        onReady: (event: any) => {
          onReady?.(event.target)
          
          // Start time update interval
          if (onTimeUpdate) {
            timeUpdateIntervalRef.current = setInterval(() => {
              const currentTime = event.target.getCurrentTime()
              onTimeUpdate(currentTime)
            }, 500)
          }
        },
        onStateChange: (event: any) => {
          onStateChange?.(event.data)
          
          // Clear interval when paused or ended
          if (event.data !== window.YT.PlayerState.PLAYING) {
            if (timeUpdateIntervalRef.current) {
              clearInterval(timeUpdateIntervalRef.current)
            }
          }
        }
      }
    })
    
    return () => {
      // Cleanup
      if (timeUpdateIntervalRef.current) {
        clearInterval(timeUpdateIntervalRef.current)
      }
      if (playerRef.current) {
        playerRef.current.destroy()
      }
    }
  }, [apiReady, videoId])
  
  return (
    <div 
      ref={containerRef}
      className="aspect-video w-full bg-black rounded-lg overflow-hidden"
    />
  )
}
```

## Player State Management

### Player States
```typescript
enum YouTubePlayerState {
  UNSTARTED = -1,
  ENDED = 0,
  PLAYING = 1,
  PAUSED = 2,
  BUFFERING = 3,
  CUED = 5
}

const getPlayerStateLabel = (state: number): string => {
  switch (state) {
    case YouTubePlayerState.UNSTARTED: return 'Not Started'
    case YouTubePlayerState.ENDED: return 'Ended'
    case YouTubePlayerState.PLAYING: return 'Playing'
    case YouTubePlayerState.PAUSED: return 'Paused'
    case YouTubePlayerState.BUFFERING: return 'Buffering'
    case YouTubePlayerState.CUED: return 'Cued'
    default: return 'Unknown'
  }
}
```

### State Change Handler
```typescript
const handlePlayerStateChange = (state: number) => {
  switch (state) {
    case YouTubePlayerState.PLAYING:
      setIsPlaying(true)
      setIsPaused(false)
      break
      
    case YouTubePlayerState.PAUSED:
      setIsPlaying(false)
      setIsPaused(true)
      break
      
    case YouTubePlayerState.ENDED:
      setIsPlaying(false)
      handleVideoComplete()
      break
      
    case YouTubePlayerState.BUFFERING:
      // Optional: show loading indicator
      setIsBuffering(true)
      break
  }
}
```

## Player Controls

### Custom Control Interface
```typescript
interface PlayerControls {
  play: () => void
  pause: () => void
  seekTo: (seconds: number) => void
  getCurrentTime: () => number
  getDuration: () => number
  getVolume: () => number
  setVolume: (volume: number) => void
  mute: () => void
  unMute: () => void
  isMuted: () => boolean
}

const usePlayerControls = (player: any): PlayerControls | null => {
  if (!player) return null
  
  return {
    play: () => player.playVideo(),
    pause: () => player.pauseVideo(),
    seekTo: (seconds: number) => player.seekTo(seconds, true),
    getCurrentTime: () => player.getCurrentTime(),
    getDuration: () => player.getDuration(),
    getVolume: () => player.getVolume(),
    setVolume: (volume: number) => player.setVolume(volume),
    mute: () => player.mute(),
    unMute: () => player.unMute(),
    isMuted: () => player.isMuted()
  }
}
```

### Custom Controls UI
```typescript
import { Play, Pause, Volume2, VolumeX, SkipBack, SkipForward } from 'lucide-react'
import { Button } from '@/components/ui/button'
import { Slider } from '@/components/ui/slider'

export function VideoControls({ controls }: { controls: PlayerControls }) {
  const [isPlaying, setIsPlaying] = useState(false)
  const [volume, setVolume] = useState(100)
  const [isMuted, setIsMuted] = useState(false)
  const [currentTime, setCurrentTime] = useState(0)
  const [duration, setDuration] = useState(0)
  
  const togglePlayPause = () => {
    if (isPlaying) {
      controls.pause()
    } else {
      controls.play()
    }
    setIsPlaying(!isPlaying)
  }
  
  const toggleMute = () => {
    if (isMuted) {
      controls.unMute()
    } else {
      controls.mute()
    }
    setIsMuted(!isMuted)
  }
  
  const handleVolumeChange = (value: number[]) => {
    const newVolume = value[0]
    setVolume(newVolume)
    controls.setVolume(newVolume)
    setIsMuted(newVolume === 0)
  }
  
  const skip = (seconds: number) => {
    const newTime = Math.max(0, Math.min(duration, currentTime + seconds))
    controls.seekTo(newTime)
  }
  
  return (
    <div className="flex items-center space-x-4 p-4 bg-background border rounded-lg">
      {/* Play/Pause */}
      <Button variant="ghost" size="icon" onClick={togglePlayPause}>
        {isPlaying ? <Pause className="h-5 w-5" /> : <Play className="h-5 w-5" />}
      </Button>
      
      {/* Skip buttons */}
      <Button variant="ghost" size="icon" onClick={() => skip(-10)}>
        <SkipBack className="h-5 w-5" />
      </Button>
      <Button variant="ghost" size="icon" onClick={() => skip(10)}>
        <SkipForward className="h-5 w-5" />
      </Button>
      
      {/* Progress bar */}
      <div className="flex-1">
        <Slider
          value={[currentTime]}
          max={duration}
          step={1}
          onValueChange={(value) => controls.seekTo(value[0])}
        />
        <div className="flex justify-between text-xs text-muted-foreground mt-1">
          <span>{formatTime(currentTime)}</span>
          <span>{formatTime(duration)}</span>
        </div>
      </div>
      
      {/* Volume control */}
      <div className="flex items-center space-x-2">
        <Button variant="ghost" size="icon" onClick={toggleMute}>
          {isMuted ? <VolumeX className="h-5 w-5" /> : <Volume2 className="h-5 w-5" />}
        </Button>
        <Slider
          value={[volume]}
          max={100}
          step={1}
          className="w-24"
          onValueChange={handleVolumeChange}
        />
      </div>
    </div>
  )
}
```

## Progress Tracking

### Watch Time Tracking
```typescript
const useWatchTimeTracking = (
  player: any,
  lessonId: string,
  userId: string
) => {
  const watchedSegments = useRef<Set<number>>(new Set())
  const lastSaveTime = useRef<number>(0)
  
  const trackWatchTime = useCallback(async (currentTime: number) => {
    // Track in 5-second segments
    const segment = Math.floor(currentTime / 5)
    watchedSegments.current.add(segment)
    
    // Save every 30 seconds
    const now = Date.now()
    if (now - lastSaveTime.current > 30000) {
      const watchedSeconds = watchedSegments.current.size * 5
      
      await saveWatchProgress({
        lessonId,
        userId,
        watchedSeconds,
        lastPosition: currentTime,
        updatedAt: new Date().toISOString()
      })
      
      lastSaveTime.current = now
    }
  }, [lessonId, userId])
  
  return { trackWatchTime, watchedSegments: watchedSegments.current }
}
```

## Video Metadata

### Extracting Video Info
```typescript
interface VideoMetadata {
  title: string
  description: string
  thumbnailUrl: string
  duration: number
  author: string
}

const fetchVideoMetadata = async (videoId: string): Promise<VideoMetadata> => {
  // Using YouTube Data API (requires API key)
  const response = await fetch(
    `https://www.googleapis.com/youtube/v3/videos?id=${videoId}&part=snippet,contentDetails&key=${process.env.NEXT_PUBLIC_YOUTUBE_API_KEY}`
  )
  
  const data = await response.json()
  const video = data.items[0]
  
  return {
    title: video.snippet.title,
    description: video.snippet.description,
    thumbnailUrl: video.snippet.thumbnails.high.url,
    duration: parseYouTubeDuration(video.contentDetails.duration),
    author: video.snippet.channelTitle
  }
}

// Parse ISO 8601 duration (PT1H2M10S) to seconds
const parseYouTubeDuration = (duration: string): number => {
  const match = duration.match(/PT(\d+H)?(\d+M)?(\d+S)?/)
  if (!match) return 0
  
  const hours = parseInt(match[1]) || 0
  const minutes = parseInt(match[2]) || 0
  const seconds = parseInt(match[3]) || 0
  
  return hours * 3600 + minutes * 60 + seconds
}
```

## Playlist Support

### Playlist Player
```typescript
interface PlaylistPlayerProps {
  playlistId: string
  onVideoChange?: (videoId: string, index: number) => void
}

export function PlaylistPlayer({ playlistId, onVideoChange }: PlaylistPlayerProps) {
  const [currentVideoIndex, setCurrentVideoIndex] = useState(0)
  const playerRef = useRef<any>(null)
  
  useEffect(() => {
    if (!window.YT) return
    
    playerRef.current = new window.YT.Player('playlist-player', {
      playerVars: {
        listType: 'playlist',
        list: playlistId,
        autoplay: 1
      },
      events: {
        onStateChange: (event: any) => {
          if (event.data === window.YT.PlayerState.PLAYING) {
            const videoData = event.target.getVideoData()
            const playlistIndex = event.target.getPlaylistIndex()
            
            setCurrentVideoIndex(playlistIndex)
            onVideoChange?.(videoData.video_id, playlistIndex)
          }
        }
      }
    })
  }, [playlistId])
  
  return <div id="playlist-player" className="aspect-video w-full" />
}
```

## Performance Optimization

### Lazy Loading Videos
```typescript
const LazyYouTubePlayer = ({ videoId }: { videoId: string }) => {
  const [loadPlayer, setLoadPlayer] = useState(false)
  const thumbnailUrl = `https://img.youtube.com/vi/${videoId}/maxresdefault.jpg`
  
  if (!loadPlayer) {
    return (
      <div 
        className="relative aspect-video w-full cursor-pointer group"
        onClick={() => setLoadPlayer(true)}
      >
        <img 
          src={thumbnailUrl} 
          alt="Video thumbnail"
          className="w-full h-full object-cover rounded-lg"
        />
        <div className="absolute inset-0 flex items-center justify-center bg-black/30 group-hover:bg-black/40 transition-colors">
          <div className="w-20 h-20 bg-red-600 rounded-full flex items-center justify-center">
            <Play className="h-10 w-10 text-white ml-1" />
          </div>
        </div>
      </div>
    )
  }
  
  return <YouTubePlayer videoId={videoId} autoplay />
}
```

## Error Handling

```typescript
const handlePlayerError = (error: any) => {
  const errorMessages = {
    2: 'Invalid video ID',
    5: 'HTML5 player error',
    100: 'Video not found or private',
    101: 'Video owner disabled embedding',
    150: 'Video owner disabled embedding'
  }
  
  const message = errorMessages[error.data] || 'Unknown error occurred'
  console.error('YouTube Player Error:', message)
  
  // Show user-friendly error
  toast({
    title: 'Video Error',
    description: message,
    variant: 'destructive'
  })
}
```

## Utility Functions

```typescript
// Format seconds to HH:MM:SS or MM:SS
const formatTime = (seconds: number): string => {
  const hours = Math.floor(seconds / 3600)
  const minutes = Math.floor((seconds % 3600) / 60)
  const secs = Math.floor(seconds % 60)
  
  if (hours > 0) {
    return `${hours}:${minutes.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}`
  }
  return `${minutes}:${secs.toString().padStart(2, '0')}`
}

// Extract video ID from YouTube URL
const extractVideoId = (url: string): string | null => {
  const patterns = [
    /youtube\.com\/watch\?v=([^&]+)/,
    /youtube\.com\/embed\/([^?]+)/,
    /youtu\.be\/([^?]+)/
  ]
  
  for (const pattern of patterns) {
    const match = url.match(pattern)
    if (match) return match[1]
  }
  
  return null
}
```