#### Math Markdown Renderer
**File**: [src/components/MathMarkdown.tsx](mdc:src/components/MathMarkdown.tsx)

Advanced markdown with KaTeX math rendering:

```typescript
export default function MathMarkdown({ content }: MathMarkdownProps) {
  const containerRef = useRef<HTMLDivElement>(null)

  useEffect(() => {
    const loadKatex = async () => {
      const katex = await import('katex')
      
      // Process display math \[ ... \]
      const displayMath = containerRef.current.querySelectorAll('.math-display')
      displayMath.forEach((element) => {
        const math = element.textContent || ''
        element.innerHTML = katex.renderToString(math, { 
          displayMode: true,
          throwOnError: false
        })
      })
    }
    loadKatex()
  }, [content])
}
```

**Supported Math Syntax**:
- Inline math: `\( E = mc^2 \)`
- Display math: `\[ F = ma \]`
- Physics symbols and equations
- Custom macros for common expressions

