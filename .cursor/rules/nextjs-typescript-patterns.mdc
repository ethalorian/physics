## Security Patterns

### Input Validation
Always validate inputs:

```typescript
// API route validation
const validateAssignmentData = (data: any): data is AssignmentData => {
  return (
    typeof data.title === 'string' &&
    data.title.length > 0 &&
    Array.isArray(data.questions) &&
    data.questions.every(q => validateQuestion(q))
  )
}

// Component validation
const handleSubmit = (e: React.FormEvent) => {
  e.preventDefault()
  
  if (!formData.title.trim()) {
    setError('Title is required')
    return
  }
  
  if (formData.questions.length === 0) {
    setError('At least one question is required')
    return
  }
  
  // Proceed with submission
}
```

### Authentication Checks
Always check authentication and authorization:

```typescript
// In components
const { data: session } = useSession()
const userRole = getUserRole(session?.user?.email)

if (!session) {
  return <div>Please sign in to access this page.</div>
}

if (userRole !== 'admin' && userRole !== 'teacher') {
  return <div>Access denied. Insufficient permissions.</div>
}

// In API routes
const session = await auth()
if (!session?.user?.email) {
  return NextResponse.json({ error: 'Unauthorized' }, { status: 401 })
}
```

## Testing Patterns

### Component Testing
Structure tests consistently:

```typescript
import { render, screen } from '@testing-library/react'
import { AssignmentProvider } from '@/contexts/AssignmentContext'
import ComponentName from './ComponentName'

const renderWithProvider = (component: React.ReactElement) => {
  return render(
    <AssignmentProvider>
      {component}
    </AssignmentProvider>
  )
}

describe('ComponentName', () => {
  it('should render correctly', () => {
    renderWithProvider(<ComponentName title="Test" />)
    expect(screen.getByText('Test')).toBeInTheDocument()
  })
  
  it('should handle user interactions', async () => {
    const mockHandler = jest.fn()
    renderWithProvider(<ComponentName onAction={mockHandler} />)
    
    // Test interactions
  })
})
```

### API Route Testing
Test API routes with proper mocking:

```typescript
import { GET, POST } from './route'
import { auth } from '@/app/api/auth/[...nextauth]/route'

jest.mock('@/app/api/auth/[...nextauth]/route')
const mockAuth = auth as jest.MockedFunction<typeof auth>

describe('/api/endpoint', () => {
  beforeEach(() => {
    mockAuth.mockResolvedValue({
      user: { email: 'test@example.com' }
    })
  })
  
  it('should handle GET requests', async () => {
    const request = new Request('http://localhost/api/endpoint')
    const response = await GET(request)
    
    expect(response.status).toBe(200)
  })
})
```