## Component Patterns

### Function Component Structure
Use consistent component patterns:

```typescript
// Import organization (always follow this order)
import { useState, useEffect } from 'react'           // React imports
import { NextRequest, NextResponse } from 'next/server' // Next.js imports
import { useSession } from 'next-auth/react'          // External packages
import { Button } from '@/components/ui/button'       // Internal with @/ prefix
import { useAssignments } from '@/contexts/AssignmentContext'

// Component definition
interface ComponentNameProps {
  // Props interface
}

export default function ComponentName({ prop1, prop2 }: ComponentNameProps) {
  // State declarations
  const [state, setState] = useState<StateType>(initialValue)
  
  // Context usage
  const { assignments, createAssignment } = useAssignments()
  
  // Effects
  useEffect(() => {
    // Effect logic
  }, [dependencies])
  
  // Event handlers
  const handleAction = useCallback((data: DataType) => {
    // Handler logic
  }, [dependencies])
  
  // Render
  return (
    <div className="component-container">
      {/* JSX content */}
    </div>
  )
}
```

### Context Provider Pattern
Follow the provider pattern established in [src/app/layout.tsx](mdc:src/app/layout.tsx):

```typescript
// Provider hierarchy
<AuthProvider>
