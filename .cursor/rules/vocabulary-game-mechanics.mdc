# Vocabulary Game Mechanics

## Spaced Repetition System

### Review Scheduling
```typescript
function calculateNextReviewDate(
  masteryLevel: number,
  correctStreak: number
): Date {
  // Intervals based on mastery (in days)
  const intervals = {
    beginner: [1, 2, 4, 7],           // < 50% mastery
    intermediate: [7, 14, 30],         // 50-80% mastery
    advanced: [30, 60, 90, 180]        // > 80% mastery
  }
  
  let category: keyof typeof intervals
  if (masteryLevel < 50) category = 'beginner'
  else if (masteryLevel < 80) category = 'intermediate'
  else category = 'advanced'
  
  const intervalIndex = Math.min(correctStreak, intervals[category].length - 1)
  const daysUntilReview = intervals[category][intervalIndex]
  
  const nextReview = new Date()
  nextReview.setDate(nextReview.getDate() + daysUntilReview)
  
  return nextReview
}
```

## Difficulty Adaptation

### Dynamic Difficulty Adjustment
```typescript
interface DifficultyState {
  currentLevel: number    // 1-10
  consecutiveCorrect: number
  consecutiveWrong: number
  adaptationRate: number  // How fast to adjust
}

function adjustDifficulty(
  state: DifficultyState,
  wasCorrect: boolean
): DifficultyState {
  const newState = { ...state }
  
  if (wasCorrect) {
    newState.consecutiveCorrect++
    newState.consecutiveWrong = 0
    
    // Increase difficulty after 3 correct
    if (newState.consecutiveCorrect >= 3) {
      newState.currentLevel = Math.min(10, 
        newState.currentLevel + state.adaptationRate
      )
      newState.consecutiveCorrect = 0
    }
  } else {
    newState.consecutiveWrong++
    newState.consecutiveCorrect = 0
    
    // Decrease difficulty after 2 wrong
    if (newState.consecutiveWrong >= 2) {
      newState.currentLevel = Math.max(1, 
        newState.currentLevel - state.adaptationRate
      )
      newState.consecutiveWrong = 0
    }
  }
  
  return newState
}
```

## Game-Specific Mechanics

### Hangman Hints System
```typescript
interface HintSystem {
  hintsAvailable: number
  hintTypes: {
    revealVowel: { cost: 10, cooldown: 0 }
    revealConsonant: { cost: 15, cooldown: 0 }
    showDefinition: { cost: 5, cooldown: 0 }
    removeWrongLetters: { cost: 20, cooldown: 30 }
  }
}

function useHint(
  hintType: keyof HintSystem['hintTypes'],
  gameState: HangmanGameState
): HangmanGameState {
  const hint = HINTS[hintType]
  
  if (gameState.score < hint.cost) {
    return gameState // Not enough points
  }
  
  const newState = { ...gameState }
  newState.score -= hint.cost
  newState.hintsUsed++
  
  switch (hintType) {
    case 'revealVowel':
      // Reveal random unguessed vowel
      const vowels = 'AEIOU'.split('')
      const unguessedVowels = vowels.filter(
        v => !newState.guessedLetters.includes(v)
      )
      if (unguessedVowels.length) {
        const vowel = unguessedVowels[Math.floor(Math.random() * unguessedVowels.length)]
        newState.guessedLetters.push(vowel)
      }
      break
    
    // Other hint implementations
  }
  
  return newState
}
```

### Word Shoot Mechanics
```typescript
interface WordShootPhysics {
  gravity: number          // Pixels per frame²
  terminalVelocity: number // Max fall speed
  windFactor: number       // Horizontal drift
}

function updateFallingWords(
  words: FallingWord[],
  deltaTime: number,
  physics: WordShootPhysics
): FallingWord[] {
  return words.map(word => {
    // Apply gravity
    let newSpeed = word.speed + physics.gravity * deltaTime
    newSpeed = Math.min(newSpeed, physics.terminalVelocity)
    
    // Update position
    const newY = word.y + newSpeed * deltaTime
    const newX = word.x + Math.sin(Date.now() / 1000) * physics.windFactor
    
    return {
      ...word,
      x: newX,
      y: newY,
      speed: newSpeed
    }
  }).filter(word => word.y < window.innerHeight) // Remove off-screen
}

function checkCollision(
  word: FallingWord,
  shooterPosition: number,
  selectedDefinition: string
): boolean {
  const isInRange = Math.abs(word.x - shooterPosition) < 50
  const isCorrectDefinition = word.term.definition === selectedDefinition
  
  return isInRange && isCorrectDefinition
}
```

### Speed Quiz Timer System
```typescript
interface TimerState {
  totalTime: number        // Total time for quiz
  timeRemaining: number
  timePerQuestion: number
  bonusTimePerCorrect: number
}

function handleQuizAnswer(
  isCorrect: boolean,
  timerState: TimerState
): TimerState {
  const newState = { ...timerState }
  
  if (isCorrect) {
    // Add bonus time for correct answer
    newState.timeRemaining += timerState.bonusTimePerCorrect
    newState.timeRemaining = Math.min(
      newState.timeRemaining,
      timerState.totalTime
    )
  } else {
    // Penalty: no bonus time
    // Could also subtract time for wrong answers
  }
  
  return newState
}
```

## Combo and Streak Systems

### Streak Bonuses
```typescript
interface StreakSystem {
  current: number
  best: number
  multiplier: number
  milestones: { count: number, bonus: number }[]
}

function updateStreak(
  streak: StreakSystem,
  isCorrect: boolean,
  baseScore: number
): { newStreak: StreakSystem, scoreBonus: number } {
  if (!isCorrect) {
    return {
      newStreak: { ...streak, current: 0, multiplier: 1.0 },
      scoreBonus: 0
    }
  }
  
  const newStreak = { ...streak }
  newStreak.current++
  newStreak.best = Math.max(newStreak.best, newStreak.current)
  
  // Calculate multiplier (caps at 3x)
  newStreak.multiplier = Math.min(3.0, 1.0 + (newStreak.current * 0.1))
  
  // Check for milestone bonuses
  let bonusPoints = 0
  const milestone = streak.milestones.find(
    m => m.count === newStreak.current
  )
  if (milestone) {
    bonusPoints = milestone.bonus
  }
  
  const totalBonus = Math.floor(baseScore * (newStreak.multiplier - 1)) + bonusPoints
  
  return { newStreak, scoreBonus: totalBonus }
}
```

### Combo System for Matching Game
```typescript
interface ComboSystem {
  currentCombo: number
  comboTimer: number        // Seconds until combo breaks
  comboThreshold: number    // Seconds between matches for combo
}

function updateCombo(
  combo: ComboSystem,
  matchTime: number
): ComboSystem {
  const timeSinceLastMatch = Date.now() - matchTime
  
  if (timeSinceLastMatch <= combo.comboThreshold * 1000) {
    return {
      ...combo,
      currentCombo: combo.currentCombo + 1,
      comboTimer: combo.comboThreshold
    }
  } else {
    return {
      ...combo,
      currentCombo: 0,
      comboTimer: combo.comboThreshold
    }
  }
}
```

