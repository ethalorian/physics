## Combo System

### Combo Tracking
```typescript
const updateCombo = (correct: boolean) => {
  if (correct) {
    setCombo(prev => {
      const newCombo = prev + 1
      const multiplier = getComboMultiplier(newCombo)
      
      if (newCombo % 5 === 0) {
        showComboNotification(newCombo, multiplier)
      }
      
      return newCombo
    })
  } else {
    setCombo(0)
    setComboMultiplier(1.0)
  }
}

const getComboMultiplier = (combo: number): number => {
  if (combo >= 20) return 3.0
  if (combo >= 15) return 2.5
  if (combo >= 10) return 2.0
  if (combo >= 5) return 1.5
  return 1.0
}
```

### Combo Display
```typescript
{combo >= 3 && (
  <motion.div
    initial={{ scale: 0 }}
    animate={{ scale: 1 }}
    className="absolute top-4 right-4 bg-primary text-white px-4 py-2 rounded-full"
  >
    <span className="text-2xl font-bold">{combo}x</span>
    <span className="text-sm ml-2">COMBO!</span>
  </motion.div>
)}
```

## Power-Ups System

### Power-Up Types
```typescript
type PowerUp = 
  | 'freeze_time'      // Pause timer for 10 seconds
  | 'reveal_answer'    // Show correct answer
  | 'double_points'    // 2x points for next 3 questions
  | 'extra_life'       // Add one life
  | 'skip_question'    // Move to next without penalty

interface PowerUpState {
  available: PowerUp[]
  active: PowerUp | null
  uses: Record<PowerUp, number>
}
```

### Power-Up Activation
```typescript
const activatePowerUp = (powerUp: PowerUp) => {
  if (!isPowerUpAvailable(powerUp)) return
  
  setPowerUpState(prev => ({
    ...prev,
    active: powerUp,
    uses: {
      ...prev.uses,
      [powerUp]: (prev.uses[powerUp] || 0) + 1
    }
  }))
  
  // Apply power-up effect
  switch (powerUp) {
    case 'freeze_time':
      pauseTimer(10000)
      break
    case 'double_points':
      setPointsMultiplier(2.0)
      setQuestionsWithDoublePoints(3)
      break
    case 'extra_life':
      setLives(prev => prev + 1)
      break
  }
}
```

## Results Summary

### End Game Summary
```typescript
interface GameSummary {
  totalQuestions: number
  correctAnswers: number
  accuracy: number
  totalScore: number
  timeElapsed: number
  highestStreak: number
  hintsUsed: number
  livesRemaining: number
  perfect: boolean
  rank: string // S, A, B, C, D, F
}

const generateGameSummary = (): GameSummary => {
  const accuracy = correctAnswers / totalQuestions
  const perfect = accuracy === 1 && hintsUsed === 0
  
  return {
    totalQuestions,
    correctAnswers,
    accuracy,
    totalScore: finalScore,
    timeElapsed: Date.now() - startTime,
    highestStreak: maxStreak,
    hintsUsed,
    livesRemaining: lives,
    perfect,
    rank: calculateRank(accuracy, finalScore)
  }
}

const calculateRank = (accuracy: number, score: number): string => {
  if (accuracy === 1 && score >= 1000) return 'S'
  if (accuracy >= 0.9 && score >= 800) return 'A'
  if (accuracy >= 0.75 && score >= 600) return 'B'
  if (accuracy >= 0.6 && score >= 400) return 'C'
  if (accuracy >= 0.5) return 'D'
  return 'F'
}
```