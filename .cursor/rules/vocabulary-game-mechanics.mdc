## Power-ups and Boosters

### Power-up System
```typescript
interface PowerUp {
  id: string
  type: 'time_freeze' | 'double_points' | 'auto_complete' | 'shield'
  duration: number        // Seconds active
  cooldown: number       // Seconds before reuse
  cost: number          // Score cost to activate
}

function activatePowerUp(
  powerUp: PowerUp,
  gameState: any
): any {
  if (gameState.score < powerUp.cost) return gameState
  
  const newState = { 
    ...gameState,
    score: gameState.score - powerUp.cost,
    activePowerUps: [...gameState.activePowerUps, {
      ...powerUp,
      activatedAt: Date.now(),
      expiresAt: Date.now() + powerUp.duration * 1000
    }]
  }
  
  return newState
}
```