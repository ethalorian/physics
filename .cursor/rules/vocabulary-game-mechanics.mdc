# Vocabulary Game Mechanics

## Game Flow Pattern

Every vocabulary game follows this lifecycle:

```typescript
// 1. Initialize
const initializeGame = () => {
  setGameState({
    status: 'ready',
    score: 0,
    lives: 3,
    currentIndex: 0,
    streak: 0
  })
}

// 2. Start
const startGame = () => {
  setGameState(prev => ({
    ...prev,
    status: 'playing',
    startTime: Date.now()
  }))
}

// 3. Process Answer
const checkAnswer = (userAnswer: string) => {
  const correct = userAnswer.toLowerCase() === correctAnswer.toLowerCase()
  
  if (correct) {
    handleCorrectAnswer()
  } else {
    handleIncorrectAnswer()
  }
}

// 4. Complete
const completeGame = () => {
  const finalScore = calculateFinalScore()
  saveGameCompletion(finalScore)
  setGameState(prev => ({ ...prev, status: 'completed' }))
}
```

## Difficulty System

### Difficulty Selection
```typescript
interface DifficultySettings {
  easy: {
    lives: 5
    timeLimit: null // No time limit
    hintsAvailable: 3
    scoreMultiplier: 1.0
  }
  medium: {
    lives: 3
    timeLimit: 60 // seconds per term
    hintsAvailable: 2
    scoreMultiplier: 1.5
  }
  hard: {
    lives: 1
    timeLimit: 30
    hintsAvailable: 0
    scoreMultiplier: 2.0
  }
}
```

### Dynamic Difficulty Adjustment
```typescript
const adjustDifficulty = (performance: GamePerformance) => {
  // Increase difficulty if performing well
  if (performance.accuracy > 0.9 && performance.avgTime < 10) {
    return 'hard'
  }
  // Decrease if struggling
  if (performance.accuracy < 0.5) {
    return 'easy'
  }
  return 'medium'
}
```

## Scoring Components

### Points Calculation
```typescript
interface ScoreFactors {
  basePoints: number        // Fixed per question
  speedBonus: number       // Based on time taken
  streakBonus: number      // Consecutive correct
  difficultyMultiplier: number // 1.0, 1.5, 2.0
  perfectBonus: number     // All correct, no hints
  hintPenalty: number      // -20 per hint used
}

const calculateQuestionScore = (factors: ScoreFactors): number => {
  const {
    basePoints,
    speedBonus,
    streakBonus,
    difficultyMultiplier,
    perfectBonus,
    hintPenalty
  } = factors
  
  return Math.floor(
    (basePoints + speedBonus + streakBonus + perfectBonus - hintPenalty) 
    * difficultyMultiplier
  )
}
```

### Speed Bonus Calculation
```typescript
const calculateSpeedBonus = (timeElapsed: number, difficulty: string): number => {
  const thresholds = {
    easy: { fast: 15, medium: 30 },
    medium: { fast: 10, medium: 20 },
    hard: { fast: 5, medium: 10 }
  }
  
  const { fast, medium } = thresholds[difficulty]
  
  if (timeElapsed < fast) return 50
  if (timeElapsed < medium) return 25
  return 0
}
```

### Streak System
```typescript
const updateStreak = (correct: boolean) => {
  if (correct) {
    setStreak(prev => {
      const newStreak = prev + 1
      
      // Milestone bonuses
      if (newStreak === 5) showMessage('🔥 5 in a row! +50 bonus')
      if (newStreak === 10) showMessage('⚡ Unstoppable! +100 bonus')
      
      return newStreak
    })
  } else {
    setStreak(0)
  }
}

const getStreakBonus = (streak: number): number => {
  if (streak >= 10) return 100
  if (streak >= 5) return 50
  return streak * 5 // 5 points per consecutive correct
}
```

## Lives System

### Lives Management
```typescript
const handleLivesSystem = () => {
  const decrementLife = () => {
    setLives(prev => {
      const newLives = prev - 1
      
      if (newLives === 0) {
        endGame('lives_depleted')
      } else if (newLives === 1) {
        showWarning('⚠️ Last life remaining!')
      }
      
      return newLives
    })
  }
  
  const earnExtraLife = () => {
    setLives(prev => Math.min(prev + 1, 5)) // Max 5 lives
    showMessage('❤️ Extra life earned!')
  }
  
  return { decrementLife, earnExtraLife }
}
```

### Lives Earning Conditions
```typescript
// Earn extra life for milestones
if (score % 500 === 0 && score > 0) {
  earnExtraLife()
}

// Earn for perfect streak
if (streak === 10) {
  earnExtraLife()
}
```

## Hint System

### Hint Implementation
```typescript
const useHint = (term: VocabularyTerm, hintLevel: number) => {
  if (hintsRemaining === 0) {
    showMessage('No hints remaining')
    return null
  }
  
  setHintsRemaining(prev => prev - 1)
  setHintsUsed(prev => prev + 1)
  
  // Progressive hints
  switch (hintLevel) {
    case 1:
      // Show first letter
      return term.term[0] + '_'.repeat(term.term.length - 1)
    
    case 2:
      // Show definition start
      return term.definition.substring(0, 20) + '...'
    
    case 3:
      // Show related term
      return `Related to: ${term.relatedTerms?.[0] || 'N/A'}`
    
    default:
      return null
  }
}
```

