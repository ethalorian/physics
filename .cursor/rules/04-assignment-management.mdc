### Submission Handling
**File**: [src/contexts/AssignmentContext.tsx](mdc:src/contexts/AssignmentContext.tsx)

```typescript
export function saveSubmission(submission: Omit<Submission, 'id' | 'submitted_at'>) {
  const newSubmission: Submission = {
    ...submission,
    id: `submission-${Date.now()}`,
    submitted_at: new Date().toISOString()
  }
  
  // Replace existing submission for same assignment/user
  const filteredSubmissions = existingSubmissions.filter(
    sub => !(sub.assignment_id === submission.assignment_id && 
             sub.user_id === submission.user_id)
  )
  
  localStorage.setItem('physics-submissions', JSON.stringify([
    ...filteredSubmissions, 
    newSubmission
  ]))
}
```

## Grading System

### Automatic Grading
**Multiple Choice & Numerical**: Instant grading with score calculation
**Open Response**: AI-powered grading using OpenAI API

### AI Grading Implementation
**File**: [src/app/api/grade-open-response/route.ts](mdc:src/app/api/grade-open-response/route.ts)

```typescript
const gradingPrompt = `
Grade this physics response using the provided rubric.
Question: ${question.question}
Student Answer: ${studentAnswer}
Rubric: ${JSON.stringify(question.rubric)}
Expected Concepts: ${question.correctConcepts}
Common Misconceptions: ${question.commonMisconceptions}
`

const response = await openai.chat.completions.create({
  model: "gpt-4",
  messages: [{ role: "user", content: gradingPrompt }]
})
```

