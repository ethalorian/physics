## Mathematical Validation

### Input Validation for Physics
Validate physics inputs with proper error handling:

```typescript
// Validate numerical physics answers
const validatePhysicsAnswer = (answer: number, correct: number, tolerance: number = 0.01) => {
  const percentError = Math.abs((answer - correct) / correct)
  return percentError <= tolerance
}

// Unit validation
const validateUnit = (providedUnit: string, expectedUnit: string) => {
  const unitAliases = {
    'meters/second': 'm/s',
    'meters per second': 'm/s',
    'newtons': 'N'
  }
  
  return providedUnit === expectedUnit || 
         unitAliases[providedUnit] === expectedUnit
}
```

### Error Messages for Physics
Provide educational error messages:

```typescript
const physicsErrorMessages = {
