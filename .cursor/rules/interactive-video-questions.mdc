# Interactive Video Questions System

## Overview

Embed questions at specific timestamps in YouTube videos for interactive learning experiences. Core implementation in lesson content pages.

## Video Player Integration

### YouTube Player Setup
```typescript
import { useRef, useEffect, useState } from 'react'

interface YouTubePlayer {
  getCurrentTime: () => number
  pauseVideo: () => void
  playVideo: () => void
  seekTo: (seconds: number) => void
}

const useYouTubePlayer = (videoId: string) => {
  const playerRef = useRef<YouTubePlayer | null>(null)
  const [player, setPlayer] = useState<YouTubePlayer | null>(null)
  
  useEffect(() => {
    // Load YouTube IFrame API
    const tag = document.createElement('script')
    tag.src = 'https://www.youtube.com/iframe_api'
    document.head.appendChild(tag)
    
    window.onYouTubeIframeAPIReady = () => {
      const ytPlayer = new window.YT.Player('youtube-player', {
        videoId: videoId,
        events: {
          onReady: (event) => {
            playerRef.current = event.target
            setPlayer(event.target)
          },
          onStateChange: handleStateChange
        }
      })
    }
  }, [videoId])
  
  return { player, playerRef }
}
```

## Question Timing System

### Question Marker Structure
```typescript
interface VideoQuestion {
  id: string
  timestamp: number // seconds into video
  question: string
  type: 'multiple-choice' | 'open-response' | 'true-false'
  options?: string[]
  correctAnswer?: number | string
  explanation?: string
  allowSkip: boolean
  requireCorrect: boolean // Must answer correctly to continue
}

interface VideoLesson {
  videoId: string
  title: string
  description: string
  questions: VideoQuestion[]
  duration: number
}
```

### Time-Based Question Triggering
```typescript
const useVideoQuestions = (
  player: YouTubePlayer | null,
  questions: VideoQuestion[]
) => {
  const [currentQuestion, setCurrentQuestion] = useState<VideoQuestion | null>(null)
  const [answeredQuestions, setAnsweredQuestions] = useState<Set<string>>(new Set())
  const checkIntervalRef = useRef<NodeJS.Timeout>()
  
  useEffect(() => {
    if (!player) return
    
    // Check current time every 500ms
    checkIntervalRef.current = setInterval(() => {
      const currentTime = player.getCurrentTime()
      
      // Find question at current timestamp
      const questionAtTime = questions.find(q => 
        Math.abs(q.timestamp - currentTime) < 0.5 && 
        !answeredQuestions.has(q.id)
      )
      
      if (questionAtTime) {
        player.pauseVideo()
        setCurrentQuestion(questionAtTime)
      }
    }, 500)
    
    return () => {
      if (checkIntervalRef.current) {
        clearInterval(checkIntervalRef.current)
      }
    }
  }, [player, questions, answeredQuestions])
  
  return {
    currentQuestion,
    setCurrentQuestion,
    answeredQuestions,
    setAnsweredQuestions
  }
}
```

## Question Overlay Component

### Modal Question Display
```typescript
import { Dialog, DialogContent, DialogHeader, DialogTitle } from '@/components/ui/dialog'
import { Button } from '@/components/ui/button'
import { RadioGroup, RadioGroupItem } from '@/components/ui/radio-group'

interface VideoQuestionModalProps {
  question: VideoQuestion
  onAnswer: (answer: string | number, correct: boolean) => void
  onSkip?: () => void
}

export function VideoQuestionModal({
  question,
  onAnswer,
  onSkip
}: VideoQuestionModalProps) {
  const [selectedAnswer, setSelectedAnswer] = useState<string | number>('')
  const [showFeedback, setShowFeedback] = useState(false)
  const [isCorrect, setIsCorrect] = useState(false)
  
  const handleSubmit = () => {
    const correct = selectedAnswer === question.correctAnswer
    setIsCorrect(correct)
    setShowFeedback(true)
    
    if (!question.requireCorrect || correct) {
      setTimeout(() => {
        onAnswer(selectedAnswer, correct)
      }, 2000)
    }
  }
  
  return (
    <Dialog open={true} onOpenChange={() => {}}>
      <DialogContent className="sm:max-w-md">
        <DialogHeader>
          <DialogTitle>
            Question at {formatTimestamp(question.timestamp)}
          </DialogTitle>
        </DialogHeader>
        
        <div className="space-y-4">
          <p className="text-lg">{question.question}</p>
          
          {question.type === 'multiple-choice' && (
            <RadioGroup 
              value={String(selectedAnswer)} 
              onValueChange={setSelectedAnswer}
            >
              {question.options?.map((option, index) => (
                <div key={index} className="flex items-center space-x-2">
                  <RadioGroupItem value={String(index)} id={`option-${index}`} />
                  <label htmlFor={`option-${index}`}>{option}</label>
                </div>
              ))}
            </RadioGroup>
          )}
          
          {showFeedback && (
            <div className={cn(
              "p-4 rounded-lg",
              isCorrect ? "bg-green-100 dark:bg-green-900" : "bg-red-100 dark:bg-red-900"
            )}>
              <p className="font-medium">
                {isCorrect ? '✅ Correct!' : '❌ Incorrect'}
              </p>
              {question.explanation && (
                <p className="mt-2 text-sm">{question.explanation}</p>
              )}
            </div>
          )}
          
          <div className="flex justify-between">
            {question.allowSkip && !showFeedback && (
              <Button variant="ghost" onClick={onSkip}>
                Skip
              </Button>
            )}
            
            <Button 
              onClick={handleSubmit}
              disabled={!selectedAnswer || showFeedback}
              className="ml-auto"
            >
              Submit Answer
            </Button>
          </div>
        </div>
      </DialogContent>
    </Dialog>
  )
}
```

## Progress Tracking

### Video Progress State
```typescript
interface VideoProgress {
  lessonId: string
  videoId: string
  watchedDuration: number // total seconds watched
  questionsAnswered: {
    questionId: string
    answer: string | number
    correct: boolean
    timestamp: number
    attemptedAt: string
  }[]
  completed: boolean
  completedAt?: string
}
```

### Saving Progress
```typescript
const saveVideoProgress = async (progress: VideoProgress) => {
  const { data, error } = await supabase
    .from('video_lesson_progress')
    .upsert({
      student_id: userId,
      lesson_id: progress.lessonId,
      video_id: progress.videoId,
      watched_duration: progress.watchedDuration,
      questions_answered: progress.questionsAnswered,
      completed: progress.completed,
      completed_at: progress.completedAt,
      updated_at: new Date().toISOString()
    }, {
      onConflict: 'student_id,lesson_id'
    })
  
  if (error) throw error
  return data
}
```

