          className="absolute top-0 w-3 h-3 bg-yellow-500 rounded-full transform -translate-y-1/4"
          style={{ left: `${(q.timestamp / duration) * 100}%` }}
          title={`Question at ${formatTimestamp(q.timestamp)}`}
        />
      ))}
    </div>
  )
}
```

## Admin Question Editor

### Adding Questions to Videos
```typescript
interface VideoQuestionEditorProps {
  videoId: string
  duration: number
  existingQuestions: VideoQuestion[]
  onSave: (questions: VideoQuestion[]) => void
}

export function VideoQuestionEditor({
  videoId,
  duration,
  existingQuestions,
  onSave
}: VideoQuestionEditorProps) {
  const [questions, setQuestions] = useState<VideoQuestion[]>(existingQuestions)
  const [editingQuestion, setEditingQuestion] = useState<VideoQuestion | null>(null)
  
  const addQuestion = (timestamp: number) => {
    const newQuestion: VideoQuestion = {
      id: `q-${Date.now()}`,
      timestamp,
      question: '',
      type: 'multiple-choice',
      options: ['', '', '', ''],
      correctAnswer: 0,
      allowSkip: false,
      requireCorrect: false
    }
    
    setEditingQuestion(newQuestion)
  }
  
  return (
    <div className="space-y-4">
      <div className="flex justify-between items-center">
        <h3 className="text-lg font-medium">Video Questions</h3>
        <Button onClick={() => addQuestion(0)}>
          Add Question
        </Button>
      </div>
      
      {/* Question list */}
      <div className="space-y-2">
        {questions
          .sort((a, b) => a.timestamp - b.timestamp)
          .map(q => (
            <div key={q.id} className="flex items-center justify-between p-4 border rounded-lg">
              <div>
                <p className="font-medium">{formatTimestamp(q.timestamp)}</p>
                <p className="text-sm text-muted-foreground">{q.question}</p>
              </div>
              <div className="flex space-x-2">
                <Button 
                  variant="outline" 
                  size="sm"
                  onClick={() => setEditingQuestion(q)}
                >
                  Edit
                </Button>
                <Button 
                  variant="destructive" 
                  size="sm"
                  onClick={() => removeQuestion(q.id)}
                >
                  Delete
                </Button>
              </div>
            </div>
          ))}
      </div>
    </div>
  )
}
```

## Completion Criteria

### Video Lesson Completion
```typescript
const checkVideoCompletion = (progress: VideoProgress): boolean => {
  // Must watch at least 80% of video
  const watchPercentage = progress.watchedDuration / videoDuration
  const watchedEnough = watchPercentage >= 0.8
  
  // Must answer all required questions correctly
  const allQuestionsAnswered = videoQuestions.every(q => 
    progress.questionsAnswered.some(a => 
      a.questionId === q.id && 
      (!q.requireCorrect || a.correct)
    )
  )
  
  return watchedEnough && allQuestionsAnswered
}
```

## Utility Functions

```typescript
// Format seconds to MM:SS
const formatTimestamp = (seconds: number): string => {
  const mins = Math.floor(seconds / 60)
  const secs = Math.floor(seconds % 60)
  return `${mins}:${secs.toString().padStart(2, '0')}`
}

// Parse timestamp string to seconds
const parseTimestamp = (timestamp: string): number => {
  const [mins, secs] = timestamp.split(':').map(Number)
  return mins * 60 + secs
}
```

## Database Schema

```sql
CREATE TABLE video_lesson_progress (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  student_id UUID NOT NULL REFERENCES students(id),
  lesson_id TEXT NOT NULL,
  video_id TEXT NOT NULL,
  watched_duration INTEGER DEFAULT 0,
  questions_answered JSONB DEFAULT '[]'::jsonb,
  completed BOOLEAN DEFAULT FALSE,
  completed_at TIMESTAMPTZ,
  created_at TIMESTAMPTZ DEFAULT NOW(),
  updated_at TIMESTAMPTZ DEFAULT NOW(),
  UNIQUE(student_id, lesson_id)
);

CREATE INDEX idx_video_progress_student ON video_lesson_progress(student_id);
CREATE INDEX idx_video_progress_lesson ON video_lesson_progress(lesson_id);
```