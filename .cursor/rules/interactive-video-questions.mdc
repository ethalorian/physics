## Pause and Question Display

### Time Monitoring Pattern
```typescript
function useVideoTimeMonitor(player: YouTubePlayer, questions: VideoQuestion[]) {
  const [currentTime, setCurrentTime] = useState(0)
  const [activeQuestion, setActiveQuestion] = useState<VideoQuestion | null>(null)
  
  useEffect(() => {
    const interval = setInterval(async () => {
      if (!player) return
      
      const time = await player.getCurrentTime()
      setCurrentTime(time)
      
      // Check if we hit a question timestamp
      const question = questions.find(q => 
        !q.answered && 
        Math.abs(time - q.timestamp) < 0.5
      )
      
      if (question) {
        player.pauseVideo()
        setActiveQuestion(question)
      }
    }, 100)
    
    return () => clearInterval(interval)
  }, [player, questions])
  
  return { currentTime, activeQuestion }
}
```

## Question Overlay Component

```typescript
function VideoQuestionOverlay({ 
  question, 
  onAnswer,
  onSkip 
}: VideoQuestionOverlayProps) {
  return (
    <div className="absolute inset-0 bg-black/80 flex items-center justify-center z-50">
      <Card className="max-w-2xl w-full mx-4">
        <CardHeader>
          <CardTitle>Question at {formatTime(question.timestamp)}</CardTitle>
        </CardHeader>
        <CardContent>
          {/* Render question using existing QuestionRenderer */}
          <QuestionRenderer
            question={question.question}
            answer={answer}
            onAnswerChange={setAnswer}
          />
        </CardContent>
        <CardFooter className="flex justify-between">
          <Button variant="outline" onClick={onSkip}>
            Skip Question
          </Button>
          <Button onClick={() => onAnswer(answer)}>
            Submit Answer
          </Button>
        </CardFooter>
      </Card>
    </div>
  )
}
```

