## Video Controls Enhancement

### Custom Controls with Questions
```typescript
function VideoControls({ 
  player, 
  questions,
  currentTime 
}: VideoControlsProps) {
  return (
    <div className="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/80 p-4">
      {/* Progress bar with question markers */}
      <div className="relative h-2 bg-gray-700 rounded mb-2">
        <div 
          className="absolute h-full bg-primary rounded"
          style={{ width: `${(currentTime / totalDuration) * 100}%` }}
        />
        
        {/* Question markers */}
        {questions.map(q => (
          <button
            key={q.id}
            className={cn(
              "absolute w-3 h-3 rounded-full -top-0.5",
              q.answered ? "bg-green-500" : "bg-yellow-500"
            )}
            style={{ left: `${(q.timestamp / totalDuration) * 100}%` }}
            onClick={() => player.seekTo(q.timestamp, true)}
          />
        ))}
      </div>
      
      {/* Play/pause, time display, etc. */}
    </div>
  )
}
```

