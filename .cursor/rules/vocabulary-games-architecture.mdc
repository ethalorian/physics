## Animation Patterns

Use Framer Motion for game animations:

```typescript
import { motion, AnimatePresence } from 'framer-motion'

<AnimatePresence mode="wait">
  <motion.div
    key={currentTerm}
    initial={{ opacity: 0, x: 100 }}
    animate={{ opacity: 1, x: 0 }}
    exit={{ opacity: 0, x: -100 }}
    transition={{ duration: 0.3 }}
  >
    <TermCard term={terms[currentTerm]} />
  </motion.div>
</AnimatePresence>
```

## Accessibility

### Keyboard Controls
```typescript
useEffect(() => {
  const handleKeyPress = (e: KeyboardEvent) => {
    if (e.key === 'Enter') handleSubmit()
    if (e.key === 'Escape') handlePause()
    if (e.key === ' ' && canUseHint) useHint()
  }
  
  window.addEventListener('keydown', handleKeyPress)
  return () => window.removeEventListener('keydown', handleKeyPress)
}, [handleSubmit, handlePause, canUseHint])
```

### Screen Reader Support
```typescript
<div 
  role="status" 
  aria-live="polite"
  aria-atomic="true"
  className="sr-only"
>
  {`Score: ${score}. Lives remaining: ${lives}. Current term ${currentTerm + 1} of ${totalTerms}`}
</div>
```

## Performance Optimization

### Vocabulary Loading
```typescript
// Preload vocabulary for selected unit
useEffect(() => {
  if (selectedUnit) {
    const terms = vocabularyUnits.find(u => u.id === selectedUnit)?.terms
    setPreloadedTerms(terms)
  }
}, [selectedUnit, vocabularyUnits])
```

### Audio Preloading
```typescript
// Preload sound effects
useEffect(() => {
  const sounds = {
    correct: new Audio('/sounds/correct.mp3'),
    incorrect: new Audio('/sounds/incorrect.mp3'),
    complete: new Audio('/sounds/complete.mp3')
  }
  
  // Preload
  Object.values(sounds).forEach(sound => sound.load())
  
  setSoundEffects(sounds)
}, [])
```

## Testing Patterns

```typescript
describe('VocabularyGame', () => {
  it('should calculate score correctly', () => {
    const score = calculateScore({
      correct: true,
      timeElapsed: 5000,
      difficulty: 'medium',
      streak: 3,
      hintsUsed: 1
    })
    
    expect(score).toBeGreaterThan(0)
  })
  
  it('should track completion', async () => {
    await completeGame({
      gameType: 'hangman',
      unitId: 'unit-1',
      score: 500,
      perfect: true
    })
    
    expect(completedGames).toHaveLength(1)
  })
})
```