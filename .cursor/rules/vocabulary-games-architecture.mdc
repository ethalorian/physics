## Scoring System

### Base Score Calculation
```typescript
function calculateScore(gameType: string, performance: GamePerformance): number {
  const basePoints = {
    'hangman': 100,
    'matching': 150,
    'word-shoot': 200,
    'speed-quiz': 50
  }
  
  const base = basePoints[gameType]
  const difficultyMultiplier = {
    'easy': 1.0,
    'medium': 1.5,
    'hard': 2.0
  }
  
  // Calculate with bonuses
  let score = base * difficultyMultiplier[performance.difficulty]
  
  // Time bonus (if applicable)
  if (performance.timeBonus) {
    score += Math.floor(performance.timeRemaining * 10)
  }
  
  // Streak bonus
  if (performance.streak > 3) {
    score *= (1 + (performance.streak - 3) * 0.1)
  }
  
  // Accuracy bonus
  const accuracy = performance.correct / performance.total
  if (accuracy > 0.8) {
    score *= 1.2
  }
  
  return Math.floor(score)
}
```

## Progress Tracking

### Student Progress Model
```typescript
interface VocabularyProgress {
  student_id: string
  term_id: string
  mastery_level: number        // 0-100
  times_practiced: number
  times_correct: number
  times_incorrect: number
  last_practiced: string
  next_review_due?: string     // Spaced repetition
}
```

### Mastery Calculation
```typescript
function calculateMastery(progress: VocabularyProgress): number {
  const accuracy = progress.times_correct / progress.times_practiced
  const recency = daysSince(progress.last_practiced)
  
  // Decay over time (spaced repetition)
  const decayFactor = Math.max(0.5, 1 - (recency / 30))
  
  return Math.floor(accuracy * decayFactor * 100)
}
```

