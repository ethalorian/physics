# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-min-32-characters-generate-with-openssl-rand-base64-32

# Token Encryption Key (Required for secure token storage)
# Generate with: openssl rand -base64 32
# Best practice: Store in secret manager in production (Google Cloud Secret Manager, AWS Secrets Manager, etc.)
TOKEN_ENCRYPTION_KEY=your-encryption-key-min-32-characters

# Google OAuth (Google Cloud Console)
# Best practice: In production, retrieve these from a secure secret manager
# Never commit actual credentials to version control
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Optional: Secret Manager Configuration (for production)
# Choose one of the following secret manager configurations:

# Option 1: Google Cloud Secret Manager
# GCP_PROJECT_ID=your-project-id
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account-key.json
# Or provide service account key as JSON string:
# GCP_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# Option 2: Vercel (auto-detected when deployed to Vercel)
# No additional configuration needed - secrets are managed through Vercel dashboard

# Option 3: Allow environment variables in production (less secure)
# ALLOW_ENV_SECRETS=true

# Google RISC (Cross-Account Protection)
# Service account key for RISC API access (path to JSON file)
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./service-account-key.json
# Or provide the JSON content directly (for deployment platforms)
# GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# RISC webhook URL (optional, defaults to NEXTAUTH_URL/api/risc/webhook)
# RISC_WEBHOOK_URL=https://your-domain.com/api/risc/webhook

# Optional: YouTube API (for video metadata)
NEXT_PUBLIC_YOUTUBE_API_KEY=your-youtube-api-key
